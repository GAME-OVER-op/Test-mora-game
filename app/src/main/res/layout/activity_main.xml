<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- УГЛОВАЯ РАМКА С НЕОНОМ -->
    <com.mora.gamedock.FrameBorderView
        android:id="@+id/frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- КОНТЕНТ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- ЛЕВЫЙ КЛАСТЕР: CPU -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/cpuFreq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GHz"
                android:textColor="#B9B8B8"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <com.mora.gamedock.GlowRingView
                android:id="@+id/cpuRing"
                android:layout_width="150dp"
                android:layout_height="150dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:letterSpacing="0.2"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/perfButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\u0411\u0430\u043b\u0430\u043d\u0441"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingHorizontal="22dp"
                android:paddingVertical="8dp"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- ЦЕНТР (пока пусто, потом — оверлей поверх игры) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.15"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="14dp">

            <TextView
                android:id="@+id/rootStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\u2026"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/batteryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingHorizontal="10dp" />

                <TextView
                    android:id="@+id/tempText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--\u00b0C"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingHorizontal="10dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ПРАВЫЙ КЛАСТЕР: GPU -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/gpuFreq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MHz"
                android:textColor="#B9B8B8"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <com.mora.gamedock.GlowRingView
                android:id="@+id/gpuRing"
                android:layout_width="150dp"
                android:layout_height="150dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPU"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:letterSpacing="0.2"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
