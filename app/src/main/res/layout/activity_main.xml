<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/game_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Target package + root hint -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/target_package_label"
            android:textColor="@color/white"
            android:alpha="0.7"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/target_package"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/pill_unselected"
            android:hint="@string/target_package_hint"
            android:textColorHint="#80FFFFFF"
            android:textColor="@color/white"
            android:inputType="text"
            android:padding="12dp"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/root_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/root_required"
            android:textColor="@color/accent"
            android:textSize="12sp" />

        <!-- ================= PERFORMANCE PANEL ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="15dp"
            android:background="@drawable/panel_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="start|center_vertical"
                android:background="@drawable/panel_header_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/perf_title"
                android:textColor="@color/white"
                android:alpha="0.85"
                android:textSize="15sp" />

            <!-- live CPU / GPU rings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <com.redmagic.touchsettings.RingView
                    android:id="@+id/ring_cpu"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="150dp" />

                <com.redmagic.touchsettings.RingView
                    android:id="@+id/ring_gpu"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="150dp" />
            </LinearLayout>

            <!-- performance mode selector -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:paddingStart="16dp"
                android:text="@string/perf_mode"
                android:textColor="@color/white"
                android:alpha="0.5"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="18dp">

                <TextView
                    android:id="@+id/mode_balance"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="54dp"
                    android:gravity="center"
                    android:background="@drawable/pill_bg"
                    android:text="@string/perf_mode_balance"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/mode_performance"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:background="@drawable/pill_bg"
                    android:text="@string/perf_mode_performance"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/mode_beyond"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:background="@drawable/pill_bg"
                    android:text="@string/perf_mode_beyond"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ================= TOUCH ADJUST PANEL ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="15dp"
            android:background="@drawable/panel_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="start|center_vertical"
                android:background="@drawable/panel_header_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/touch_adjust"
                android:textColor="@color/white"
                android:alpha="0.85"
                android:textSize="15sp" />

            <!-- sample rate -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/touch_sample_rate"
                    android:textColor="@color/white"
                    android:alpha="0.5"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/sample_high"
                    android:layout_width="120dp"
                    android:layout_height="54dp"
                    android:gravity="center"
                    android:background="@drawable/pill_bg"
                    android:text="@string/touch_sample_rate_high"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/sample_ultra"
                    android:layout_width="120dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:background="@drawable/pill_bg"
                    android:text="@string/touch_sample_rate_ultra"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- sensitivity slider -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:paddingStart="16dp"
                android:text="@string/touch_sensitive"
                android:textColor="@color/white"
                android:alpha="0.5"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seek_sensitive"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_marginTop="6dp"
                android:max="4"
                android:progress="2"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:progressDrawable="@drawable/seekbar_progress"
                android:thumb="@drawable/seekbar_thumb" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="22dp"
                android:paddingEnd="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="@string/touch_sensitive_down"
                    android:textColor="@color/white"
                    android:alpha="0.5"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/touch_sensitive_up"
                    android:textColor="@color/white"
                    android:alpha="0.5"
                    android:textSize="11sp" />
            </RelativeLayout>

            <!-- follow slider -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:paddingStart="16dp"
                android:text="@string/touch_follow"
                android:textColor="@color/white"
                android:alpha="0.5"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seek_follow"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_marginTop="6dp"
                android:max="4"
                android:progress="2"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:progressDrawable="@drawable/seekbar_progress"
                android:thumb="@drawable/seekbar_thumb" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="22dp"
                android:paddingEnd="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="@string/touch_follow_down"
                    android:textColor="@color/white"
                    android:alpha="0.5"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/touch_follow_up"
                    android:textColor="@color/white"
                    android:alpha="0.5"
                    android:textSize="11sp" />
            </RelativeLayout>

            <!-- micro sensitivity slider -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:paddingStart="16dp"
                android:text="@string/micro_sensitivity"
                android:textColor="@color/white"
                android:alpha="0.5"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seek_micro"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_marginTop="6dp"
                android:max="4"
                android:progress="2"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:progressDrawable="@drawable/seekbar_progress"
                android:thumb="@drawable/seekbar_thumb" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="@string/micro_sensitivity_decrease_instruction_text"
                    android:textColor="@color/white"
                    android:alpha="0.5"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/micro_sensitivity_increase_instruction_text"
                    android:textColor="@color/white"
                    android:alpha="0.5"
                    android:textSize="11sp" />
            </RelativeLayout>
        </LinearLayout>

        <!-- ================= NETWORK PANEL ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="15dp"
            android:background="@drawable/panel_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="start|center_vertical"
                android:background="@drawable/panel_header_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/net_title"
                android:textColor="@color/white"
                android:alpha="0.85"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/net_wifi_low_latency"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/net_wifi_low_latency_desc"
                        android:textColor="@color/white"
                        android:alpha="0.5"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/wifi_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- ================= DISPLAY / LIGHT GAMMA PANEL ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/panel_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="start|center_vertical"
                android:background="@drawable/panel_header_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/display_title"
                android:textColor="@color/white"
                android:alpha="0.85"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:paddingStart="16dp"
                android:text="@string/display_gamma"
                android:textColor="@color/white"
                android:alpha="0.5"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="18dp">

                <TextView
                    android:id="@+id/gamma_default"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="54dp"
                    android:gravity="center"
                    android:background="@drawable/pill_bg"
                    android:text="@string/display_gamma_default"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/gamma_racing"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:background="@drawable/pill_bg"
                    android:text="@string/display_gamma_racing"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/gamma_shooting"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:background="@drawable/pill_bg"
                    android:text="@string/display_gamma_shooting"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
